class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        n=len(nums)
        hashmap={}
        for i in range(0,n):  # i is index
            remaining = target - nums[i]  
            if remaining in hashmap:
                return hashmap[remaining],i   # return index of remaining in hashmap, and i
            hashmap[nums[i]] = i     # else add in hashmap the value corresponding to index i in nums and also give key as i
